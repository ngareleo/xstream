# xstream environment configuration
#
# Copy this file to `.env` at the repo root and fill in the values.
# `.env` is gitignored — never commit real credentials.
#
# Both `bun run dev` scripts (client and server-rust) source this file at
# startup via `set -a; . ../.env; set +a`. Vars defined here become process
# env for both Rsbuild (which bakes the `PUBLIC_*` ones into the bundle)
# and the Rust server (which reads `OTEL_*`, `HW_ACCEL`, etc. via
# `std::env::var`).
#
# Putting creds here (rather than in `~/.zshrc`) avoids a common footgun:
# tmux panes inherit the env of the shell that started the session, so
# vars exported into `.zshrc` AFTER a tmux session was launched don't
# reach new panes — meaning `bun run dev` spawns children with stale env
# and your telemetry silently goes to the wrong place.

# ── Seq ───────────────────────────────────────────────────────────────────────
# Admin password used only when creating the Seq container for the first time.
# After the first run the password is stored in SEQ_STORE (~/.seq-store).
SEQ_ADMIN_PASSWORD=

# Override the default Seq data store location (default: ~/.seq-store).
# SEQ_STORE=/path/to/seq-store

# ── OpenTelemetry (server) ────────────────────────────────────────────────────
# OTLP exporter base URL. Dev default = local Seq. The feature flag
# `flag.useAxiomExporter` (toggled in the in-app Settings → Flags tab) switches
# the server at boot to read from the *_AXIOM_* pair below instead. Requires
# app restart to take effect; see docs/architecture/Deployment/04-Axiom-Production-Backend.md.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:5341/ingest/otlp

# Comma-separated key=value headers added to every OTLP export request.
# Local Seq: create an API key (Settings → API Keys) and paste the value below.
OTEL_EXPORTER_OTLP_HEADERS=X-Seq-ApiKey=

# Axiom (dev path — used when flag.useAxiomExporter is ON). Mint a Basic
# ingest-only token in the Axiom UI (Settings → API tokens), scoped to the
# `xstream` dataset, then paste it below. See 04-Axiom-Production-Backend.md
# § "API tokens" for the bring-up checklist.
OTEL_EXPORTER_OTLP_AXIOM_ENDPOINT=https://api.axiom.co
OTEL_EXPORTER_OTLP_AXIOM_HEADERS=Authorization=Bearer <xstream-server-dev>,X-Axiom-Dataset=xstream

# ── OpenTelemetry (client bundle) ─────────────────────────────────────────────
# Baked into the browser bundle at build time by Rsbuild (PUBLIC_ prefix required).
# Dev default = the Rsbuild proxy path (/ingest/otlp → local Seq); no CORS issues.
# The same `flag.useAxiomExporter` toggle switches the client to the *_AXIOM_*
# pair on next page load — no restart needed client-side.
PUBLIC_OTEL_ENDPOINT=/ingest/otlp
PUBLIC_OTEL_HEADERS=X-Seq-ApiKey=

PUBLIC_OTEL_AXIOM_ENDPOINT=https://api.axiom.co
PUBLIC_OTEL_AXIOM_HEADERS=Authorization=Bearer <xstream-client-dev>,X-Axiom-Dataset=xstream

# ── FFmpeg / hardware acceleration ────────────────────────────────────────────
# auto  = probe GPU encoder at startup and exit 1 on failure (the default)
# off   = force software encode — use only for benchmarking or when HW is
#         genuinely unavailable. Software 4K encode stalls continuously.
HW_ACCEL=auto

# Dev overrides — bypass the manifest-pinned install (scripts/ffmpeg-manifest.json)
# and skip the version check. Intended for experimenting with a specific ffmpeg
# build, not for production. Normal flow is `bun run setup-ffmpeg` which installs
# the exact pinned jellyfin-ffmpeg version for your platform.
# FFMPEG_PATH=/usr/bin/ffmpeg
# FFPROBE_PATH=/usr/bin/ffprobe

# ── Test fixtures ─────────────────────────────────────────────────────────────
# Directory containing the source movies for the chunker encode tests. When
# set, `bun test` runs real ffmpeg encodes against these files; when unset,
# the encode tests skip cleanly.
#
# Expected basenames inside this dir (case-sensitive — symlink if your local
# filenames differ):
#   Mad Max- Fury Road (2015).mkv
#   Furiosa- A Mad Max Saga (2024) 4K.mkv
#
# Easiest setup: run /setup-local — it prompts for this path and writes it
# back here automatically.
# XSTREAM_TEST_MEDIA_DIR=/path/to/your/movies
