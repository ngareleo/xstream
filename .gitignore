node_modules/
tmp/
dist/
# bundled ffmpeg binaries per platform — populated by `bun run setup-ffmpeg`
vendor/
.env
.seq-credentials
*.db
*.db-shm
*.db-wal

# relay-compiler artifacts — generated at dev/CI startup, not committed
client/src/relay/__generated__/

*storybook.log
storybook-static

# playwright-mcp session logs/snapshots
.playwright-mcp/
client/.playwright-mcp/

# vite dep cache
client/.vite/

# dev session screenshots
*.png
*.jpg
!docs/diagrams/*.png
!src-tauri/icons/*.png

# docs tooling state
docs/.obsidian/

# architect subagent's per-machine retrieval cache
.claude/agents/architect-cache/

# migrations-lead subagent's per-machine retrieval cache
.claude/agents/migrations-lead-cache/

# subagent worktree state
.claude/worktrees/

# subagent screenshot logs (PNGs already covered by *.png above)
.claude/screenshots/*.log

# TypeScript incremental build artifacts
*.tsbuildinfo

# Cargo build output (Rust workspace under server-rust/)
target/
**/target/
Cargo.lock.bak
mprocs.log

# Tauri build artifacts — generated by `tauri build`/`tauri dev`
src-tauri/gen/
# Bundled ffmpeg binaries — staged at build time by
# `bun run setup-ffmpeg --target=tauri-bundle`, never committed.
src-tauri/resources/ffmpeg/
