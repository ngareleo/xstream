{
  "name": "client",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run relay && rsbuild dev",
    "build": "tsc && rsbuild build",
    "relay": "mkdir -p src/relay/__generated__ && relay-compiler",
    "lint": "tsc --noEmit && eslint src",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "vitest run --config vitest.storybook.config.ts"
  },
  "dependencies": {
    "@griffel/react": "^1.6.1",
    "@nova/react": "^2.9.2",
    "@nova/types": "^1.7.1",
    "graphql": "^16.9.0",
    "graphql-ws": "^5.16.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-localization": "^2.0.6",
    "react-relay": "^20.1.1",
    "react-router-dom": "^6.26.0",
    "relay-runtime": "^20.1.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@griffel/babel-preset": "^1.8.1",
    "@griffel/webpack-loader": "^2.2.23",
    "@imchhh/storybook-addon-relay": "^0.0.15",
    "@rsbuild/core": "^1.7.5",
    "@rsbuild/plugin-babel": "^1.1.2",
    "@rsbuild/plugin-react": "^1.4.6",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/react-relay": "^14.1.0",
    "@types/relay-runtime": "^20.1.1",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "babel-plugin-relay": "^20.1.1",
    "playwright": "^1.59.1",
    "relay-compiler": "^20.1.1",
    "relay-test-utils": "^20.1.1",
    "storybook": "^10.3.5",
    "storybook-react-rsbuild": "^3.3.2",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.4",
    "webpack-bundle-analyzer": "^5.3.0"
  }
}
