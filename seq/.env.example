# seq/.env.example — copy to seq/.env on the droplet and fill in.
#
# Both values are consumed by ./setup.sh and docker-compose.yml.
# Never commit the populated .env (covered by seq/.gitignore).

# Public hostname Caddy will obtain a Let's Encrypt cert for and proxy on.
# Must have a DNS A (and AAAA if applicable) record pointing at this droplet
# BEFORE ./setup.sh runs, or the cert acquisition will fail.
SEQ_HOSTNAME=seq.example.com

# Bcrypt hash of the initial Seq admin password.
# Generate with:
#   docker run --rm datalust/seq config hash <your-password>
# Then paste the entire hash (starts with "$2a$..." or similar) below.
# Seq forces a password change on first login regardless — this is just the
# bootstrap credential.
SEQ_ADMIN_PASSWORD_HASH=
